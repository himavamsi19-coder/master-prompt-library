{
  "name": "master-prompt-library",
  "productName": "Master Prompt Library",
  "main": "electron/main.js",
  "version": "0.1.0",
  "description": "Offline desktop prompt library with local Ollama AI search.",
  "author": "Master Prompt Library",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "desktop": "electron .",
    "dist": "electron-builder --win dir"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "postcss": "^8.5.14",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "local.masterprompt.library",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "desktop/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "dir"
      ],
      "signAndEditExecutable": false
    }
  }
}
